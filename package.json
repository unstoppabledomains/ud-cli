{
  "name": "@unstoppabledomains/ud-cli",
  "version": "0.1.0",
  "description": "Unstoppable Domains CLI — Search, register, and manage your domains from the command line.",
  "type": "module",
  "bin": {
    "ud": "./dist/index.js"
  },
  "files": [
    "dist/",
    "skills/",
    "README.md"
  ],
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/unstoppabledomains/ud-cli.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "bundle": "node esbuild.config.mjs",
    "build:binaries": "npm run bundle && pkg dist/ud-cli.cjs --targets node22-macos-arm64,node22-macos-x64,node22-linux-x64,node22-linux-arm64,node22-win-x64 --out-path bin/ && node scripts/rename-binaries.mjs",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "dev": "tsx src/index.ts",
    "fetch-spec": "tsx scripts/fetch-spec.ts"
  },
  "pkg": {
    "targets": [
      "node22-macos-arm64",
      "node22-macos-x64",
      "node22-linux-x64",
      "node22-linux-arm64",
      "node22-win-x64"
    ],
    "outputPath": "bin",
    "assets": ["skills/**"]
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "cli-table3": "^0.6.5",
    "commander": "^13.1.0",
    "conf": "^13.1.0",
    "keytar": "^7.9.0",
    "ora": "^9.3.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.0",
    "@yao-pkg/pkg": "^6.3.0",
    "esbuild": "^0.25.0",
    "eslint": "^9.21.0",
    "eslint-config-prettier": "^10.0.1",
    "jest": "^29.7.0",
    "prettier": "^3.5.3",
    "ts-jest": "^29.2.6",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.25.0"
  }
}
